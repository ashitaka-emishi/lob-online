{
  "id": "issue-implement",
  "name": "Issue Implement Workflow",
  "description": "Full ticket-to-merge workflow: issue start → branch → implement → doc-sync → ecosystem-docs-generate → build → test → dev-start → editor review gate → dev-stop → PR → review → merge, with six human gate checkpoints.",
  "steps": [
    {
      "id": "issue-start",
      "name": "Issue Start",
      "agentId": "issue-start",
      "inputMap": {},
      "onError": "halt"
    },
    {
      "id": "gate-plan",
      "name": "Gate: Plan Accepted (HCP 1)",
      "agentId": null,
      "inputMap": {},
      "onError": "halt",
      "gateConfig": {
        "prompt": "The implementation plan and AC checklist are shown above. Review and choose an action.",
        "choices": [
          {
            "label": "Proceed — approve plan and create branch",
            "value": "proceed",
            "onChoice": { "nextStep": null }
          },
          {
            "label": "Revise — return to issue start with adjustments",
            "value": "revise",
            "onChoice": { "nextStep": "issue-start" }
          }
        ],
        "defaultChoice": "proceed"
      }
    },
    {
      "id": "branch",
      "name": "Create Feature Branch",
      "agentId": "issue-branch",
      "inputMap": {
        "issueNumber": "$.issue-start.issueNumber"
      },
      "onError": "halt"
    },
    {
      "id": "implement",
      "name": "Implement",
      "agentId": "issue-implement",
      "inputMap": {
        "issueNumber": "$.issue-start.issueNumber",
        "editorFeedback": "$.gate-editor.note"
      },
      "onError": "halt"
    },
    {
      "id": "doc-sync",
      "name": "Sync Project Docs",
      "agentId": "doc-sync",
      "inputMap": {},
      "onError": "continue_with_warning"
    },
    {
      "id": "ecosystem-docs-generate",
      "name": "Regenerate Ecosystem Docs",
      "agentId": "ecosystem-docs-generate",
      "inputMap": {},
      "onError": "continue_with_warning"
    },
    {
      "id": "build",
      "name": "Build",
      "agentId": "dev-build",
      "inputMap": {},
      "onError": "halt"
    },
    {
      "id": "test",
      "name": "Test",
      "agentId": "dev-test",
      "inputMap": {},
      "onError": "continue_with_warning"
    },
    {
      "id": "dev-start",
      "name": "Launch Dev Server",
      "agentId": "dev-start",
      "inputMap": {},
      "onError": "halt"
    },
    {
      "id": "gate-editor",
      "name": "Gate: Editor Review (HCP 2a)",
      "agentId": null,
      "inputMap": {},
      "onError": "halt",
      "gateConfig": {
        "prompt": "The dev server is running. Review the editor in your browser, then choose an action. On Approve, the workflow stops the server automatically via the next dev-stop step. On Fix, you MUST call /dev-stop manually before the loop-back to implement takes effect — enter your feedback as a note and it will be injected into the next implementation pass.",
        "choices": [
          {
            "label": "Approve — implementation looks good; server stops automatically, then continue to push",
            "value": "approve",
            "onChoice": { "nextStep": "dev-stop" }
          },
          {
            "label": "Fix — call /dev-stop first, then enter feedback below; implementation will restart with your feedback",
            "value": "fix",
            "onChoice": { "nextStep": "implement" }
          }
        ],
        "defaultChoice": "approve"
      }
    },
    {
      "id": "dev-stop",
      "name": "Stop Dev Server",
      "agentId": "dev-stop",
      "inputMap": {},
      "onError": "continue_with_warning"
    },
    {
      "id": "gate-impl",
      "name": "Gate: Implementation Accepted (HCP 2)",
      "agentId": null,
      "inputMap": {},
      "onError": "halt",
      "gateConfig": {
        "prompt": "Editor review approved. Doc-sync, ecosystem-docs, build, and test results are shown above. Review and choose an action.",
        "choices": [
          {
            "label": "Push — approve and push to remote",
            "value": "push",
            "onChoice": { "nextStep": null }
          },
          {
            "label": "Fix — return to implementation",
            "value": "fix",
            "onChoice": { "nextStep": "implement" }
          }
        ],
        "defaultChoice": "push"
      }
    },
    {
      "id": "pr-create",
      "name": "Create Pull Request",
      "agentId": "pr-create",
      "inputMap": {},
      "onError": "halt"
    },
    {
      "id": "pr-review",
      "name": "Review Pull Request",
      "agentId": "code-review",
      "inputMap": {},
      "onError": "continue_with_warning"
    },
    {
      "id": "gate-review",
      "name": "Gate: Review Accepted (HCP 2b)",
      "agentId": null,
      "inputMap": {},
      "onError": "halt",
      "gateConfig": {
        "prompt": "PR review findings are shown above. Choose how to proceed.",
        "choices": [
          {
            "label": "Accept — proceed to merge",
            "value": "accept",
            "onChoice": { "nextStep": null }
          },
          {
            "label": "Fix all — return to implementation to address all findings",
            "value": "fix-all",
            "onChoice": { "nextStep": "implement" }
          },
          {
            "label": "Fix errors — return to implementation for error-severity only",
            "value": "fix-errors",
            "onChoice": { "nextStep": "implement" }
          }
        ],
        "defaultChoice": "accept"
      }
    },
    {
      "id": "pr-merge",
      "name": "Merge Pull Request",
      "agentId": "pr-merge",
      "inputMap": {},
      "onError": "halt"
    },
    {
      "id": "gate-merged",
      "name": "Gate: Merge Approved (HCP 3)",
      "agentId": null,
      "inputMap": {},
      "onError": "halt",
      "gateConfig": {
        "prompt": "Final checks pass. The PR is ready to squash-merge. Confirm.",
        "choices": [
          {
            "label": "Merge — squash merge and delete branch",
            "value": "merge",
            "onChoice": { "nextStep": null }
          },
          {
            "label": "Hold — stop here; do not merge",
            "value": "hold",
            "onChoice": { "nextStep": null }
          }
        ],
        "defaultChoice": "merge"
      }
    },
    {
      "id": "gate-close",
      "name": "Gate: Close Issue (HCP 4)",
      "agentId": null,
      "inputMap": {},
      "onError": "halt",
      "gateConfig": {
        "prompt": "PR merged. Merged commit SHA and issue URL shown above. Close the GitHub issue?",
        "choices": [
          {
            "label": "Close — run gh issue close with merge summary comment",
            "value": "close",
            "onChoice": { "nextStep": null }
          },
          {
            "label": "Skip — leave issue open; engineer will close manually",
            "value": "skip",
            "onChoice": { "nextStep": null }
          }
        ],
        "defaultChoice": "close"
      }
    },
    {
      "id": "close-issue",
      "name": "Close GitHub Issue",
      "agentId": "issue-close",
      "inputMap": {
        "issueNumber": "$.issue-start.issueNumber",
        "mergeCommit": "$.pr-merge.mergeCommit"
      },
      "onError": "continue_with_warning"
    }
  ]
}
