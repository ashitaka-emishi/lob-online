{
  "id": "issue-intake",
  "name": "Issue Intake Workflow",
  "description": "Turn a raw requirement into a filed, milestone-assigned GitHub issue. Gathers and refines the draft interactively, then gates on engineer approval before calling gh issue create. No branch, no artifact, no PR.",
  "steps": [
    {
      "id": "gather",
      "name": "Gather and Refine Issue Draft",
      "agentId": "issue-intake",
      "inputMap": {},
      "onError": "halt"
    },
    {
      "id": "gate-file",
      "name": "Gate: File Issue (HCP 1)",
      "agentId": null,
      "inputMap": {},
      "onError": "halt",
      "gateConfig": {
        "prompt": "The issue draft is ready. Review the full draft above and choose an action.",
        "choices": [
          {
            "label": "File — create the GitHub issue",
            "value": "file",
            "onChoice": { "nextStep": null }
          },
          {
            "label": "Revise — return to drafting",
            "value": "revise",
            "onChoice": { "nextStep": "gather" }
          }
        ],
        "defaultChoice": "file"
      }
    },
    {
      "id": "create-issue",
      "name": "Create GitHub Issue",
      "agentId": "issue-intake",
      "inputMap": {},
      "onError": "halt"
    }
  ]
}
